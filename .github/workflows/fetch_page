name: Scrape Single Webpage

on:
  workflow_dispatch:
    inputs:
      url:
        description: 'URL to scrape'
        required: true
        default: 'https://old.reddit.com/r/Barca/'

permissions:
  contents: write

jobs:
  scrape:
    runs-on: ubuntu-latest
    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Scrape the website
        run: |
          # Create a directory for the output
          mkdir -p scraped_page
          cd scraped_page
          
          # Clean previous scrapes if you only want the latest one kept
          rm -rf *
          
          # Download the page
          # -p : Download page requisites (CSS, images)
          # -k : Convert links to work locally
          # -E : Add .html extension to the file
          # -U : Use a standard browser User-Agent so sites like Reddit don't block the request
          wget -p -k -E -U "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36" "${{ github.event.inputs.url }}"

      - name: Commit and push changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"
          git add scraped_page/
          
          # Check if there are changes to commit. If yes, commit and push.
          git diff --quiet && git diff --staged --quiet || (git commit -m "Scraped: ${{ github.event.inputs.url }}" && git push)
