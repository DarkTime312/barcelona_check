name: Fetch and Save HTML

on:
  # Run manually from the Actions tab
  workflow_dispatch:
  # OR run automatically every day at midnight UTC (uncomment below)
  # schedule:
  #   - cron: '0 0 * * *'

jobs:
  update-html:
    runs-on: ubuntu-latest

    # Grant permissions needed to push back to the repo
    permissions:
      contents: write

    steps:
      # 1. Check out the repository
      - name: Checkout Repository
        uses: actions/checkout@v4

      # 2. Download the HTML page using wget
      - name: Download HTML page
        run: |
          # Replace the URL with the actual page you want to download
          wget -O downloaded-page.html https://thecascade.dev/learning-paths

      # 3. Commit and push the file if it has changed
      - name: Commit and Push changes
        run: |
          git config --global user.name "github-actions[bot]"
          git config --global user.email "github-actions[bot]@users.noreply.github.com"

          git add downloaded-page.html

          # Only commit and push if there are changes
          if git diff --staged --quiet; then
            echo "No changes to commit"
          else
            git commit -m "Automated update of downloaded-page.html"
            git push
          fi
